<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Drag Handle Area -->
    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:background="@color/outline_variant"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/outline" />

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@color/surface"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usability Experiment Dashboard"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/btnClose"
            android:layout_marginEnd="16dp" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            app:tint="@color/outline"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="Close" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CONFIGURATION SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPERIMENT CONFIGURATION"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline_variant"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tracking Switch -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@+id/switchTracking"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Tracking Session"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enables stopwatch timer &amp; feedback dialog on capture"
                                android:fontFamily="@font/be_vietnam_pro"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchTracking"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant"
                        android:layout_marginBottom="16dp" />

                    <!-- Variant Choice -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Capture Variant"
                        android:fontFamily="@font/space_grotesk"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleVariantGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVariantA"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Variant A (Full Screen)"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVariantB"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Variant B (Bottom Sheet)"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="12sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- RESULTS SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USABILITY STUDY RESULTS"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <!-- Averages / Metrics Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Variant A Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/outline_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Variant A (Full Screen)"
                            android:fontFamily="@font/space_grotesk"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAvgTimeA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time: --"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvAvgEaseA"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ease: --"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Variant B Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/outline_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Variant B (Bottom Sheet)"
                            android:fontFamily="@font/space_grotesk"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAvgTimeB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time: --"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvAvgEaseB"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ease: --"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Recommendation Alert Box -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/primary_container"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lightbulb"
                        app:tint="@color/white"
                        android:contentDescription="Recommendation" />

                    <TextView
                        android:id="@+id/tvRecommendation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Recommendation: Add usability logs to calculate the optimal capture variant."
                        android:fontFamily="@font/be_vietnam_pro"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Results Table Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Results Log"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Results Table Layout -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/surface_container_lowest"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline_variant">

                <TableLayout
                    android:id="@+id/tableResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0,1,2,3,4"
                    android:padding="8dp">

                    <!-- Header Row -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:background="@color/surface_container_low">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time A"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ease A"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="11sp"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time B"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="11sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ease B"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk"
                            android:textSize="11sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </TableRow>
                </TableLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPopulateMock"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Demo Data"
                    android:fontFamily="@font/space_grotesk"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    app:icon="@drawable/ic_lightbulb"
                    app:iconSize="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearData"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear Data"
                    android:fontFamily="@font/space_grotesk"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/error"
                    app:strokeColor="@color/error"
                    app:icon="@drawable/ic_delete"
                    app:iconSize="14dp"
                    app:iconTint="@color/error" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
