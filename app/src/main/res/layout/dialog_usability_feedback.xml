<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task Completed! 🎉"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time taken: 0.0 seconds"
        android:fontFamily="@font/space_grotesk"
        android:textColor="@color/on_surface"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Participant Field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Participant ID / Name"
        android:fontFamily="@font/space_grotesk"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxBackgroundColor="@color/surface_container_low"
        app:hintEnabled="false"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etParticipantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. P1, P2..."
            android:textColor="@color/on_surface"
            android:fontFamily="@font/be_vietnam_pro"
            android:inputType="textCapCharacters"
            android:textSize="15sp"
            android:padding="12dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Ease Rating Field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ease Rating (1 = Very Hard, 5 = Very Easy)"
        android:fontFamily="@font/space_grotesk"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupEase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEase1"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 ⭐"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEase2"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 ⭐"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEase3"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 ⭐"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEase4"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 ⭐"
            app:chipCornerRadius="20dp"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipEase5"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 ⭐"
            app:chipCornerRadius="20dp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Error Count Field -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Errors Made (Wrong taps/attempts)"
        android:fontFamily="@font/space_grotesk"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupErrors"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="24dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipError0"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Errors"
            app:chipCornerRadius="20dp"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipError1"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 Error"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipError2"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Errors"
            app:chipCornerRadius="20dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipError3Plus"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3+ Errors"
            app:chipCornerRadius="20dp" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip Log"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="@font/space_grotesk"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save Log"
            android:fontFamily="@font/space_grotesk"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
